# ============================================================================
# VYA NEXUS - ARQUIVO .env.production.template
# Template para Produção - Copie para .env.production e preencha os valores
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.production
# 2. Substitua todos os valores "COLOQUE_AQUI_SUA_CHAVE" pelas suas credenciais reais
# 3. NUNCA commite .env.production no Git
# 4. Guarde este arquivo em local seguro
# ============================================================================

# ========== AMBIENTE ==========
NODE_ENV=production
PORT=3000
VITE_FRONTEND_URL=https://seu-dominio.com

# ========== BANCO DE DADOS ==========
# Formato: mysql://usuario:senha@host:porta/banco
# Exemplo: mysql://vyauser:senha_super_segura@db.seu-host.com:3306/vya_nexus_prod
DATABASE_URL=mysql://COLOQUE_AQUI_SEU_USUARIO:COLOQUE_AQUI_SUA_SENHA@COLOQUE_AQUI_SEU_HOST:3306/vya_nexus_prod

# ========== AUTENTICAÇÃO ==========
# DESATIVAR bypass de autenticação em produção
AUTH_BYPASS=false

# JWT - Use uma string aleatória com 32+ caracteres
JWT_SECRET=COLOQUE_AQUI_UMA_CHAVE_SUPER_SEGURA_COM_32_CARACTERES_MINIMO

# ========== OAUTH MANUS (PRODUÇÃO) ==========
# App ID registrado no Manus para produção
VITE_APP_ID=vya-nexus-prod

# URLs do OAuth Manus (não mude)
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Informações do proprietário
OWNER_OPEN_ID=COLOQUE_AQUI_SEU_OWNER_OPEN_ID
OWNER_NAME=Herbert

# ========== STORAGE - AWS S3 (PRODUÇÃO) ==========
# DESATIVAR storage local em produção
USE_LOCAL_STORAGE=false

# Credenciais AWS S3
AWS_ACCESS_KEY_ID=COLOQUE_AQUI_SUA_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=COLOQUE_AQUI_SUA_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=vya-nexus-prod
AWS_S3_REGION=sa-east-1

# ========== STRIPE (PRODUÇÃO) ==========
# Use chaves LIVE do Stripe (começam com sk_live_ e pk_live_)
STRIPE_SECRET_KEY=sk_live_COLOQUE_AQUI_SUA_CHAVE_SECRETA_STRIPE
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_COLOQUE_AQUI_SUA_CHAVE_PUBLICA_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_AQUI_SEU_WEBHOOK_SECRET_STRIPE

# ========== EMAIL SMTP (PRODUÇÃO) ==========
# Configure com seu provedor de email profissional
SMTP_HOST=COLOQUE_AQUI_SEU_SMTP_HOST
SMTP_PORT=587
SMTP_USER=COLOQUE_AQUI_SEU_EMAIL_SMTP
SMTP_PASSWORD=COLOQUE_AQUI_SUA_SENHA_SMTP
SMTP_FROM=noreply@seu-dominio.com

# ========== MANUS BUILT-IN APIs ==========
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=COLOQUE_AQUI_SUA_FORGE_API_KEY
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=COLOQUE_AQUI_SUA_FRONTEND_FORGE_API_KEY

# ========== APLICAÇÃO ==========
VITE_APP_TITLE=Vya Nexus
VITE_APP_LOGO=/logo.svg

# ========== ANALYTICS (OPCIONAL) ==========
VITE_ANALYTICS_ENDPOINT=https://seu-analytics-endpoint.com
VITE_ANALYTICS_WEBSITE_ID=seu_website_id_aqui

# ========== LOGS E MONITORAMENTO (OPCIONAL) ==========
# Configure conforme necessário para seu ambiente de produção
LOG_LEVEL=info
SENTRY_DSN=COLOQUE_AQUI_SE_USAR_SENTRY

# ============================================================================
# CHECKLIST ANTES DE FAZER DEPLOY
# ============================================================================
# [ ] DATABASE_URL - Banco de dados configurado e acessível
# [ ] JWT_SECRET - Chave segura com 32+ caracteres
# [ ] VITE_APP_ID - App registrado no Manus para produção
# [ ] OWNER_OPEN_ID - ID do proprietário no Manus
# [ ] STRIPE_SECRET_KEY - Chave LIVE do Stripe (sk_live_)
# [ ] VITE_STRIPE_PUBLISHABLE_KEY - Chave LIVE do Stripe (pk_live_)
# [ ] AWS_ACCESS_KEY_ID e AWS_SECRET_ACCESS_KEY - Credenciais AWS
# [ ] SMTP_HOST, SMTP_USER, SMTP_PASSWORD - Email configurado
# [ ] BUILT_IN_FORGE_API_KEY - Chave de API Manus
# [ ] Arquivo .env.production criado (não commitado no Git)
# [ ] Todos os valores "COLOQUE_AQUI_" foram substituídos
# [ ] Teste de conexão com banco de dados realizado
# [ ] Teste de upload para S3 realizado
# [ ] Teste de envio de email realizado
# [ ] Backup do banco de dados configurado
# ============================================================================
