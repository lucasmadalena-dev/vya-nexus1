# ============================================================================
# VYA NEXUS - ARQUIVO .env PARA DESENVOLVIMENTO NO WINDOWS
# ============================================================================
# INSTRUÇÕES:
# 1. Copie TODO o conteúdo deste arquivo
# 2. Crie um arquivo chamado ".env" na RAIZ do projeto (mesma pasta do package.json)
# 3. Cole o conteúdo e preencha os valores com suas credenciais
# 4. NUNCA commite este arquivo no Git
# ============================================================================

# ========== BANCO DE DADOS ==========
# Formato: mysql://usuario:senha@host:porta/banco
# Exemplo local: mysql://root:password@localhost:3306/vya_nexus
DATABASE_URL=mysql://root:password@localhost:3306/vya_nexus

# ========== AUTENTICAÇÃO JWT ==========
# Use uma string aleatória com 32+ caracteres
JWT_SECRET=sua_chave_secreta_jwt_super_segura_com_32_caracteres_minimo

# ========== OAUTH MANUS (OBRIGATÓRIO) ==========
# Seu ID de aplicação no Manus
VITE_APP_ID=seu_app_id_aqui

# URLs do OAuth Manus (NÃO MUDE)
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# OpenID do proprietário/admin
OWNER_OPEN_ID=seu_owner_open_id_aqui
OWNER_NAME=Herbert

# ========== STRIPE (PAGAMENTOS) ==========
# Chave secreta do Stripe (começa com sk_test_ para teste)
STRIPE_SECRET_KEY=sk_test_seu_stripe_secret_key_aqui

# Chave pública do Stripe (começa com pk_test_ para teste)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_seu_stripe_publishable_key_aqui

# Secret para validar webhooks do Stripe (começa com whsec_)
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui

# ========== AWS S3 (STORAGE) ==========
# ID da chave de acesso AWS
AWS_ACCESS_KEY_ID=sua_access_key_id_aqui

# Chave secreta de acesso AWS
AWS_SECRET_ACCESS_KEY=sua_secret_access_key_aqui

# Nome do bucket S3
AWS_S3_BUCKET=vya-nexus-storage

# Região do bucket S3 (ex: sa-east-1, us-east-1)
AWS_S3_REGION=sa-east-1

# ========== EMAIL (SMTP) ==========
# Servidor SMTP do seu provedor
SMTP_HOST=smtp.seu_provedor.com

# Porta SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Usuário/email para autenticação
SMTP_USER=seu_email@vyaconcept.com.br

# Senha do email
SMTP_PASSWORD=sua_senha_smtp_aqui

# Email de origem para envios
SMTP_FROM=noreply@vyaconcept.com.br

# ========== MANUS BUILT-IN APIs ==========
# URL da API Forge do Manus (backend)
BUILT_IN_FORGE_API_URL=https://api.manus.im

# Chave de API para backend
BUILT_IN_FORGE_API_KEY=sua_forge_api_key_aqui

# URL da API Forge (frontend)
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# Chave de API para frontend
VITE_FRONTEND_FORGE_API_KEY=sua_frontend_forge_api_key_aqui

# ========== CONFIGURAÇÃO DA APLICAÇÃO ==========
# Ambiente (development, production)
NODE_ENV=development

# Porta do servidor
PORT=3000

# Título da aplicação
VITE_APP_TITLE=Vya Nexus

# Logo da aplicação
VITE_APP_LOGO=/logo.svg

# URL frontend em desenvolvimento
VITE_FRONTEND_URL=http://localhost:3000

# ========== ANALYTICS (OPCIONAL) ==========
# Endpoint de analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com

# ID do website para analytics
VITE_ANALYTICS_WEBSITE_ID=seu_website_id_aqui
